rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isCoach() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'coach';
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId);
    }
    
    match /profiles/{profileId} {
      allow read: if true;
      allow write: if isCoach();
    }
    
    match /schedules/{scheduleId} {
      allow read: if isAuthenticated();
      allow create, delete: if isCoach();
      // Allow students to update bookedSlots when booking
      allow update: if isAuthenticated();
    }
    
    match /bookings/{bookingId} {
      // Coach can read all, Student can read their own
      allow read: if isCoach() || (isAuthenticated() && resource.data.studentId == request.auth.uid);
      allow create: if isAuthenticated();
      // Coach can update status
      allow update: if isCoach() || (isAuthenticated() && resource.data.studentId == request.auth.uid);
      allow delete: if isCoach() || (isAuthenticated() && resource.data.studentId == request.auth.uid);
    }
    
    match /payments/{paymentId} {
      allow read, write: if isAuthenticated();
    }
    
    match /notifications/{notificationId} {
      allow read, write: if isAuthenticated();
    }
  }
}
